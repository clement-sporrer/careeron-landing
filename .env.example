# Cal.eu webhook secret (set in Cal.eu dashboard → Webhooks)
CAL_WEBHOOK_SECRET=your-cal-webhook-secret

# Comma-separated allowlist for form/API submissions
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
