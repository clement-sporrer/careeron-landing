# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Resend
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=CareerON <noreply@yourdomain.com>
RESEND_NOTIFY_TO=clement@sporrer.fr,hadi.hijazi@bloq-ai.net

# Cal.eu — slugs from your Cal.eu dashboard
CAL_ENTERPRISE_URL=https://cal.eu/your-name/enterprise-demo
